# Конфигурация forward-auth.
# Скопируйте в .env (docker compose) или .env.local (локальная разработка) и заполните.
# Не коммитьте реальные секреты. Для каждого проекта — свой SESSION_SECRET.

# Код доступа, который вводят пользователи. Минимум 6 символов.
# Не используйте очевидные значения вроде 1234 или 123456.
AUTH_PASSWORD=

# Ключ подписи сессионной cookie. Минимум 32 байта случайных данных, уникальный для каждого деплоя.
# Сгенерировать: openssl rand -base64 48
# Смена ключа сразу аннулирует все существующие и поддельные токены.
SESSION_SECRET=

# Публичный URL сервиса входа, например https://auth.example.com
# В продакшене — только https, иначе cookie не будет помечена Secure.
AUTH_DOMAIN=https://auth.example.com

# Аварийный сброс сессий (unix-время в секундах). Токены, выданные до этого момента, отклоняются.
# Обычно 0 или пусто. Чтобы разлогинить всех сразу: date +%s
AUTH_TOKEN_EPOCH=0

# Явный домен cookie. Нужен для многосоставных TLD (например auth.example.co.uk),
# когда автоматический расчёт даёт публичный суффикс co.uk вместо example.co.uk.
# Без ведущей точки: example.co.uk, не .example.co.uk
# Для обычных доменов (auth.example.com → example.com) оставьте пустым.
COOKIE_DOMAIN=

# Второй фактор (TOTP). Опционально. Base32-секрет для приложения-аутентификатора.
# Если задан — после кода доступа требуется 6-значный код из аутентификатора.
# Сгенерировать: python3 -c "import base64, os; print(base64.b32encode(os.urandom(20)).decode())"
# TOTP_SECRET=
