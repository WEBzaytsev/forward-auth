# Forward-Auth configuration.
# Copy to .env (for docker compose) or .env.local (for local dev) and fill in.
# NEVER commit real secrets. Use a UNIQUE SESSION_SECRET per project.

# PIN code. Minimum 6 characters. Do NOT use trivial values like 1234/123456.
AUTH_PASSWORD=

# Cookie signing key. Minimum 32 bytes of randomness, unique per deployment.
# Generate with: openssl rand -base64 48
# Rotating this value immediately invalidates ALL existing and forged tokens.
SESSION_SECRET=

# Public URL of the auth service, e.g. https://auth.example.com
# Use https in production so the auth cookie is sent only over TLS.
AUTH_DOMAIN=https://auth.example.com

# Optional global session revocation lever (unix seconds). Tokens issued before
# this time are rejected. Leave 0/empty normally; set to the current time
# (e.g. `date +%s`) to immediately invalidate ALL existing sessions.
AUTH_TOKEN_EPOCH=0

# Optional: explicit cookie domain. Set this when AUTH_DOMAIN uses a
# multi-segment TLD (e.g. auth.example.co.uk) where the automatic two-label
# heuristic would derive a public suffix (co.uk) instead of the registrable
# domain. Provide without a leading dot: example.co.uk, not .example.co.uk
# Leave empty for single-segment TLDs (auth.example.com → example.com auto).
COOKIE_DOMAIN=
