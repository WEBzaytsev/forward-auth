# Пример Caddyfile. Замените example.com на свой домен.

# Заголовки безопасности на TLS-границе.
# Подключайте к каждому сайту — и к сервису входа, и к защищённым приложениям.
(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		X-Frame-Options "DENY"
		-Server
	}
}

# Проверка доступа через forward-auth. Импортируйте на каждый закрытый сайт.
(auth) {
	forward_auth forward-auth:8080 {
		uri /
	}
}

# Сервис входа — страница ввода кода доступа.
auth.example.com {
	import security_headers

	@login path /api/login
	rate_limit @login {
		zone login_per_ip {
			key    {client_ip}
			events 5
			window 1m
		}
	}

	reverse_proxy forward-auth:8080 {
		header_up X-Real-IP {client_ip}
	}
}

# Защищённый сервис — без кода доступа не откроется.
app.example.com {
	import security_headers
	import auth
	reverse_proxy your-app:3000
}

# Открытый сервис — без import auth.
public.example.com {
	import security_headers
	reverse_proxy your-public-app:3000
}
